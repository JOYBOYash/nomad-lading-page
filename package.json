    "@types/node": "^22.14.0",
    "@types/react-google-recaptcha": "^2.1.9",
    "@vercel/node": "^5.8.16",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "overrides": {
