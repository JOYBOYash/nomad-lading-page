rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Landing Page: Allow anyone to create a waitlist entry
    match /waitlist/{documentId} {
      allow create: if true;
      allow read: if true; // Allowed to read to check for duplicates
      allow update, delete: if request.auth != null;
    }

    // Allow anyone to trigger emails via Firebase Trigger Email Extension
    match /mail/{documentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Allow anyone to store pending emails if sending fails
    match /waitlist_pending_emails/{documentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Landing Page: Allow anyone to update the global counter
    match /stats/{documentId} {
      allow get: if true;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // Blogs collection (for writing and accessing latest news)
    match /blogs/{documentId} {
      allow read, write: if true;
    }

    // Settings collection (for the blog admin password)
    match /settings/{documentId} {
      allow read, write: if true;
    }

    // Default rule for ALL other collections (protecting your other apps)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
